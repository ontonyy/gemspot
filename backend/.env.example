# Postgres connection (Render provides this in prod)
DATABASE_URL=postgresql://gemspot:gemspot@localhost:5433/gemspot?schema=public

# Server
NODE_ENV=development
PORT=4000

# CORS — comma-separated allowed origins (GitHub Pages origin in prod).
# Leave unset in dev to reflect any origin.
CORS_ORIGIN=https://ontonyy.github.io

# Auth — JWTs for register/login/refresh. Use long random secrets in prod.
JWT_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Seed admin account (moderation panel access)
ADMIN_EMAIL=admin@gemspot.ee
ADMIN_PASSWORD=admin1234
