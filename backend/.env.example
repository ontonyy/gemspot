# Postgres connection (Render provides this in prod)
DATABASE_URL=postgresql://gemspot:gemspot@localhost:5433/gemspot?schema=public

# Server
NODE_ENV=development
PORT=4000

# CORS — comma-separated allowed origins (GitHub Pages origin in prod).
# Leave unset in dev to reflect any origin.
CORS_ORIGIN=https://gavanton.github.io

# Auth (reserved — not yet wired; frontend seam consumes no auth in MVP)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
