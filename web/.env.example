# Set to the deployed backend origin to use the real API (httpPlacesApi).
# Leave unset / omit this file to use the in-app mock placesApi.
# Local dev against the Docker backend:
VITE_API_URL=http://localhost:4000

# Google sign-in (OIDC). Same value as the backend GOOGLE_CLIENT_ID — required
# for the aud check on the ID token. Unset = Google button stays disabled.
# Create the client per docs/auth-providers-setup.md.
VITE_GOOGLE_CLIENT_ID=

# Facebook sign-in (JS SDK). The Meta App ID — required to load the SDK and
# run FB.login with the email scope. Unset = Facebook button stays the
# disabled "test mode" placeholder. Backend verifies the returned token with
# FACEBOOK_APP_ID + FACEBOOK_APP_SECRET. See docs/auth-providers-setup.md.
VITE_FACEBOOK_APP_ID=

# Map basemap provider seam. One of: openfreemap | maptiler | mapbox | selfhosted.
# Default (unset) = openfreemap, no behavior change.
VITE_MAP_PROVIDER=openfreemap
# MapTiler API key (required when VITE_MAP_PROVIDER=maptiler, or for any
# VITE_MAP_STYLE hosted style below).
VITE_MAPTILER_KEY=
# Map look (Option A): use a MapTiler ready-made style instead of the custom
# fg monochrome palette. One of: streets | outdoor | satellite | custom.
# Unset / custom = the built-in fg survey-paper palette (map-style.base.json).
# Requires VITE_MAPTILER_KEY.
# VITE_MAP_STYLE=streets
# Self-hosted tiles (required when VITE_MAP_PROVIDER=selfhosted):
# VITE_SELFHOST_TILES=https://tiles.example.com/planet
# VITE_SELFHOST_GLYPHS=https://tiles.example.com/fonts/{fontstack}/{range}.pbf
